# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Auth Passwords (used for client-side role gating)
NEXT_PUBLIC_ADMIN_PASSWORD=your-admin-password
NEXT_PUBLIC_OFFICER_PASSWORD=your-officer-password

# Roboflow Vision API (Optional)
# Get your API key from: https://app.roboflow.com/settings/api
# Used for visual detection and training data collection
NEXT_PUBLIC_ROBOFLOW_API_KEY=your-roboflow-api-key-here
NEXT_PUBLIC_ROBOFLOW_WORKSPACE=roksuite
NEXT_PUBLIC_ROBOFLOW_WORKFLOW=find-stars-commander-names-commander-portraits-level-badges-and-skill-icons
NEXT_PUBLIC_ROBOFLOW_PROJECT=rok-commander-scanner-rbbb5  # For training data uploads

# Google Gemini AI (Optional — for RoK Mail generation)
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic Claude AI (Optional — for RSS node detection on KvK map)
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
